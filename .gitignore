# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
playwright-report/
playwright/.auth/
test-results/
e2e/verify-screenshots/

# Supabase
supabase/.temp/

# Claude / IDE
.claude/settings.local.json

# Logs
*.log

# Capacitor — @capacitor/assets generates these in project root; real copies live in public/icons/
/icons/
# Static manifest generated by @capacitor/assets — Next.js serves /manifest.webmanifest
# dynamically via app/manifest.ts; the static file conflicts and must not be committed.
/public/manifest.webmanifest
